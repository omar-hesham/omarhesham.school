APP_NAME="Omar Hesham School"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://omarhesham.school
APP_TIMEZONE=Africa/Cairo
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=omarhesham_school
DB_USERNAME=omarhesham_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log

MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=noreply@omarhesham.school
MAIL_FROM_NAME="Omar Hesham School"
MAILGUN_DOMAIN=mg.omarhesham.school
MAILGUN_SECRET=CHANGE_ME_MAILGUN_KEY
MAILGUN_ENDPOINT=api.mailgun.net

STRIPE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_MONTHLY_PRICE_ID=price_CHANGE_ME
STRIPE_ANNUAL_PRICE_ID=price_CHANGE_ME
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=omarhesham-uploads
AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

PLATFORM_UPLOAD_MAX_MB=20
PLATFORM_MINOR_ADS_ENABLED=false
PLATFORM_REQUIRE_PARENT_CONSENT=true

TRUSTED_PROXIES=*
